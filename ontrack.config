# ontrack configuration
# Specify the top-level directories to scan.
# For each directory, first-level subdirectories owned by members of `groups`
# will be reported.
paths:
  - /path/to/your/data

# Unix groups whose members' subdirectories should be reported.
# Can also be supplied via the --groups command-line argument (CLI takes
# precedence over this setting).
groups:
  - your_group_name

# Shell-style glob patterns for files and directories to exclude from all
# scans.  Matching is done against the base name only (not the full path).
# The default entry below ignores hidden files and directories (names that
# start with a dot).
ignore:
  - '.*'

# Named tracks used to categorise project directories.  Each key is a track
# name that can be referenced by the ``track`` field in an ``ontrack.yml``
# metadata store.  Any number of optional subfields (e.g. description, pi)
# may be added under each track name.
track:
  rna-seq:
    description: RNA sequencing analysis projects
  cnv-pipeline:
    description: Copy number variation pipeline projects
  scatac-seq:
    description: Single-cell ATAC-seq projects
